<view class="add-page">
  <view class="form-card">
    <view class="form-title">基本信息</view>
    <view class="form-item">
      <text class="label">姓名 *</text>
      <input placeholder="请输入租客姓名" data-field="name" value="{{formData.name}}" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">手机号 *</text>
      <input type="number" placeholder="请输入手机号" maxlength="11" data-field="phone" value="{{formData.phone}}" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">身份证号</text>
      <input placeholder="请输入身份证号" data-field="idCard" value="{{formData.idCard}}" bindinput="onInput"/>
    </view>
  </view>

  <view class="form-card">
    <view class="form-title">租房信息</view>
    <view class="form-item">
      <text class="label">选择房间 *</text>
      <picker mode="selector" range="{{rooms}}" range-key="roomNumber" bindchange="onRoomChange">
        <view class="picker-value {{formData.roomNumber ? '' : 'placeholder'}}">
          {{formData.roomNumber || '请选择房间'}}
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">月租金 *</text>
      <input type="digit" placeholder="请输入月租金" data-field="rent" value="{{formData.rent}}" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">押金</text>
      <input type="digit" placeholder="请输入押金" data-field="deposit" value="{{formData.deposit}}" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">入住日期</text>
      <picker mode="date" bindchange="onDateChange" value="{{formData.checkInDate}}">
        <view class="picker-value {{formData.checkInDate ? '' : 'placeholder'}}">
          {{formData.checkInDate || '请选择入住日期'}}
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">备注</text>
      <textarea placeholder="请输入备注信息（选填）" data-field="remark" value="{{formData.remark}}" bindinput="onInput"/>
    </view>
  </view>

  <view class="submit-btn" bindtap="submit">确认添加</view>
</view>
