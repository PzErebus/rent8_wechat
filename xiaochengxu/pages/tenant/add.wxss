/* 通用表单样式 */
.add-page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; padding-bottom: 200rpx; }
.form-card { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; }
.form-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; padding-bottom: 20rpx; border-bottom: 1rpx solid #f0f0f0; }
.form-item { margin-bottom: 24rpx; }
.form-item .label { display: block; font-size: 28rpx; color: #333; margin-bottom: 12rpx; font-weight: 500; }
.form-item input, .form-item textarea { width: 100%; background: #f6f6f6; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; box-sizing: border-box; }
.form-item textarea { min-height: 120rpx; }
.picker-value { background: #f6f6f6; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #333; }
.picker-value.placeholder { color: #999; }
.submit-btn { position: fixed; bottom: 40rpx; left: 30rpx; right: 30rpx; height: 96rpx; line-height: 96rpx; background: linear-gradient(135deg, #1890ff, #096dd9); color: #fff; text-align: center; font-size: 32rpx; border-radius: 48rpx; box-shadow: 0 8rpx 24rpx rgba(24,144,255,0.4); }
