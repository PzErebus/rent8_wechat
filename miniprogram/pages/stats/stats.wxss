/* pages/stats/stats.wxss */
.stats-page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; padding-bottom: 40rpx; }
.header-stats { background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%); padding: 60rpx 30rpx; margin: -24rpx -24rpx 24rpx; border-radius: 0 0 40rpx 40rpx; text-align: center; }
.header-num { font-size: 56rpx; font-weight: bold; color: #fff; }
.header-label { font-size: 28rpx; color: rgba(255,255,255,0.8); margin-top: 12rpx; display: block; }
.card { background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 20rpx; }
.card-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }
.stats-grid { display: flex; flex-wrap: wrap; }
.stat-item { width: 33.33%; display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; }
.stat-num { font-size: 36rpx; font-weight: bold; color: #333; }
.stat-num.primary { color: #1890ff; }
.stat-num.success { color: #52c41a; }
.stat-num.warning { color: #faad14; }
.stat-num.income { color: #52c41a; }
.stat-num.expense { color: #ff4d4f; }
.stat-num.profit { color: #1890ff; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.tenant-stat { display: flex; align-items: center; padding: 20rpx; background: #f6f6f6; border-radius: 16rpx; }
.tenant-icon { font-size: 60rpx; margin-right: 24rpx; }
.tenant-info { display: flex; flex-direction: column; }
.tenant-num { font-size: 44rpx; font-weight: bold; color: #333; }
.tenant-label { font-size: 26rpx; color: #999; }
