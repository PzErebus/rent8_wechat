/* 详情页样式 */
.detail-page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; padding-bottom: 200rpx; }
.detail-card { background: #fff; border-radius: 16rpx; overflow: hidden; }
.section { padding: 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; }
.edit-btn { font-size: 28rpx; color: #1890ff; }
.info-grid { display: flex; flex-wrap: wrap; }
.info-item { width: 50%; margin-bottom: 24rpx; box-sizing: border-box; }
.info-item .label { display: block; font-size: 26rpx; color: #999; margin-bottom: 8rpx; }
.info-item .value { font-size: 30rpx; color: #333; }
.info-item .value.primary { color: #1890ff; font-weight: 600; }
.info-item .input { background: #f6f6f6; border-radius: 8rpx; padding: 12rpx 16rpx; font-size: 30rpx; }
.phone-wrap { display: flex; align-items: center; }
.call-btn { font-size: 24rpx; color: #1890ff; margin-left: 16rpx; }
.bill-stats { display: flex; justify-content: space-around; padding: 20rpx 0; }
.bill-stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 40rpx; font-weight: bold; }
.stat-num.success { color: #52c41a; }
.stat-num.danger { color: #ff4d4f; }
.stat-label { font-size: 26rpx; color: #999; margin-top: 8rpx; }
.remark { font-size: 28rpx; color: #666; line-height: 1.6; }
.save-btn { height: 96rpx; line-height: 96rpx; text-align: center; background: #1890ff; color: #fff; font-size: 32rpx; margin: 30rpx; border-radius: 48rpx; }
.checkout-btn { height: 96rpx; line-height: 96rpx; text-align: center; color: #ff4d4f; font-size: 32rpx; margin: 0 30rpx 30rpx; border: 2rpx solid #ff4d4f; border-radius: 48rpx; }
.loading { text-align: center; padding: 60rpx; color: #999; }
