/* pages/index/index.wxss */

page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.main {
  width: 100%;
  box-sizing: border-box;
  padding: 30rpx;
}

/* 用户信息卡片 */
.user-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 30rpx;
  border: 4rpx solid #f0f0f0;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.user-type {
  display: flex;
  align-items: center;
}

.type-badge {
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.type-badge.trial {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #fff;
}

.type-badge.formal {
  background: linear-gradient(135deg, #07c160 0%, #05a050 100%);
  color: #fff;
}

/* 到期提醒 */
.expire-notice {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #f0f9ff;
  border: 2rpx solid #0ea5e9;
}

.expire-notice.warning {
  background: #fff7ed;
  border-color: #f97316;
}

.expire-notice.expired {
  background: #fef2f2;
  border-color: #ef4444;
}

.notice-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
}

.notice-text {
  font-size: 28rpx;
  color: #0ea5e9;
  font-weight: 500;
}

.expire-notice.warning .notice-text {
  color: #f97316;
}

.expire-notice.expired .notice-text {
  color: #ef4444;
}

.remaining-days {
  font-size: 26rpx;
  color: #f97316;
  font-weight: 600;
}

.renew-btn {
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

/* 功能菜单区域 */
.menu-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #667eea;
}

/* 到期遮罩 */
.expired-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.mask-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 50rpx;
  text-align: center;
  max-width: 80%;
}

.mask-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.mask-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.mask-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.mask-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  height: 90rpx;
  line-height: 90rpx;
  border: none;
  padding: 0 60rpx;
}

.mask-btn::after {
  border: none;
}
